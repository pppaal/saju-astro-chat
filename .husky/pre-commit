npx lint-staged

echo "Scanning for secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --verbose --no-banner || {
    echo ""
    echo "ERROR: Gitleaks detected potential secrets in staged files."
    echo "Review the findings above and remove any sensitive data."
    echo "If this is a false positive, either:"
    echo "1. Add an entry to .gitleaksignore"
    echo "2. Use git commit --no-verify (not recommended)"
    exit 1
  }
  echo "OK: No secrets detected"
else
  echo "WARN: gitleaks not installed, skipping secret scan"
  echo "Install from https://github.com/gitleaks/gitleaks"
fi

echo "Checking for Korean comments in new code..."
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
  KOREAN_FOUND=0
  for FILE in $STAGED_TS_FILES; do
    if grep -n "//.*[가-힣]\|/\*.*[가-힣]" "$FILE" >/dev/null 2>&1; then
      echo "WARN: Korean comments found in new file: $FILE"
      KOREAN_FOUND=1
    fi
  done

  if [ "$KOREAN_FOUND" -eq 1 ]; then
    echo "Consider using English comments for consistency."
    echo "(Warning only, commit will proceed)"
  else
    echo "OK: No Korean comments in new files"
  fi
fi

echo "Checking for console statements..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  CONSOLE_FOUND=0
  for FILE in $STAGED_FILES; do
    case "$FILE" in
      src/lib/logger/*|scripts/*)
        continue
        ;;
    esac

    if grep -n "console\.log\|console\.debug" "$FILE" | grep -v "// @ts-expect-error console" | grep -v "/\* .* console" >/dev/null 2>&1; then
      echo "ERROR: Found console statement in $FILE"
      CONSOLE_FOUND=1
    fi
  done

  if [ "$CONSOLE_FOUND" -eq 1 ]; then
    echo ""
    echo "Use logger instead: import { logger } from '@/lib/logger';"
    echo "If you need to keep console for debugging, add: // @ts-expect-error console"
    exit 1
  fi
  echo "OK: No console statements found"
fi

echo "OK: Pre-commit checks passed"
