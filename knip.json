{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/instrumentation.ts",
    "src/instrumentation-client.ts",
    "tests/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mts,mjs,js}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mts}"
  ],
  "ignore": [
    "src/**/*.stories.{ts,tsx}",
    "src/styles/**",
    "src/data/**",
    "tmp/**",
    "artifacts/**",
    "reports/**",
    "docs/archive/**"
  ]
}
