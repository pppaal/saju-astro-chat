{
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["icn1"],
  "env": {
    "NODE_ENV": "production",
    "NODE_OPTIONS": "--max-old-space-size=7168"
  },
  "build": {
    "env": {
      "SKIP_ENV_VALIDATION": "1",
      "NODE_OPTIONS": "--max-old-space-size=7168",
      "NEXT_PRIVATE_DISABLE_TURBOPACK": "1",
      "NEXT_DIST_DIR": ".next"
    }
  },
  "functions": {
    "app/api/calendar/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    },
    "app/api/destiny-map/chat-stream/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    },
    "app/api/destiny-matrix/ai-report/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    },
    "app/api/astrology/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    },
    "app/api/precompute-chart/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    },
    "app/api/past-life/route.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    },
    "app/api/life-prediction/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/swisseph/build/Release/**/*.node",
      "excludeFiles": "{public/images/**,artifacts/**,qa-dumps/**,reports/**,tmp/**,htmlcov/**,playwright-report/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/notifications",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
