generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String? // OAuth provider image
  role          String    @default("user") // user, admin, superadmin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 분리된 테이블 관계
  profile  UserProfile?  // 프로필 정보 (생년월일, 프로필사진 등)
  settings UserSettings? // 설정 정보 (알림, 추천코드 등)

  // 추천인 관계
  referrerId String? // 나를 추천한 유저 ID
  referrer   User?   @relation("Referrals", fields: [referrerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  referrals  User[]  @relation("Referrals") // 내가 추천한 유저들

  // 인증 관계
  accounts Account[]
  sessions Session[]

  // 서비스 데이터 관계
  interactions          UserInteraction[]
  credits               UserCredits?
  counselorChatSessions CounselorChatSession[]
  referralRewards       ReferralReward[]
  tarotReadings         TarotReading[]
  savedPersons          SavedPerson[]
  // 크레딧 변동 감사 로그 — 모든 grant/consume/refund/expire/revoke
  // 이벤트를 single source of truth 로 보존 (sum-invariant 가드 포함).
  creditTransactions    CreditTransaction[]
  // 웹 푸시 구독 (매일 아침 오늘의 운세 알림)
  pushSubscriptions     PushSubscription[]

  @@index([referrerId])
}

// 웹 푸시 구독 — "매일 아침 오늘의 운세 한 줄" 알림용 (Web Push / VAPID).
// 브라우저 PushSubscription(endpoint + p256dh/auth 키)을 유저별로 보관한다.
// 옛 PushSubscription(2026-06-06 삭제, row 0)과 별개의 새 wiring —
// 등록: POST /api/me/push-subscription, 발송: GET /api/cron/daily-fortune.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique // 푸시 서비스가 발급한 구독 URL (구독의 자연키)
  p256dh    String // 클라이언트 공개키 (payload 암호화용)
  auth      String // 인증 시크릿
  locale    String   @default("ko") // 알림 본문 언어 (ko | en)
  createdAt DateTime @default(now())
  lastSentAt DateTime? // 마지막 발송 성공 시각
  failCount Int      @default(0) // 연속 발송 실패 횟수 — 5회 이상이면 정리

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 사용자 프로필 정보 - 생년월일, 사진 등 개인 정보
model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 프로필 사진
  profilePhoto String? // User uploaded custom profile photo

  // 생년월일 정보 (사주/점성술 분석용)
  birthDate String? // YYYY-MM-DD
  birthTime String? // HH:mm
  gender    String? // M, F, U
  birthCity String?
  latitude  Float? // 출생지 위도 — 점성 하우스/진태양시 보정용
  longitude Float? // 출생지 경도 — 사주 진태양시(진경도) 보정용
  tzId      String? // Timezone ID

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([birthDate])
}

// 사용자 설정 - 추천코드 등
model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 추천 시스템
  referralCode String? @unique // 내 고유 추천 코드

  // 법령 동의 — 첫 로그인 후 LegalConsentModal 에서 기록.
  // legalAcceptedVersion 이 현재 LEGAL_VERSION 과 다르면 재동의 모달이 다시 뜬다.
  // ageConfirmedAt 은 14세 이상 self-attest (PIPA 22조의2 방어).
  legalAcceptedAt      DateTime?
  legalAcceptedVersion String?
  ageConfirmedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([referralCode])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 옛 Reading (일반 리딩 결과 archive) — production caller 0 (admin 통계
// read-only 만), create 0. TarotReading + CounselorChatSession 으로 대체.
// 2026-06-06 삭제.

model UserInteraction {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  type      String
  service   String
  rating    Int?
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, service])
}

// 옛 UserDecision (Decision Tracker Tier 2B) — production caller 0, row 0
// 으로 2026-06-06 삭제. 사용자 결정 후속 검증 학습 데이터 아이디어였음.

// 내 사람들 - 가족, 친구, 연인 정보 저장
model SavedPerson {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 기본 정보
  name      String
  relation  String // family, friend, partner, colleague
  birthDate String?
  birthTime String?
  gender    String? // M, F, U
  birthCity String?
  latitude  Float?
  longitude Float?
  tzId      String?

  // 메모
  note String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, relation])
}

// 옛 Subscription (Stripe 동기화 구독) — 프리미엄 개념 폐기 (2026-06-06)
// 와 함께 제거. BonusCreditPurchase + CreditTransaction 의 크레딧 시스템
// 으로 통일. lib/auth/premium.ts 도 같이 삭제.

// 옛 PremiumContentAccess (프리미엄 콘텐츠 열람 기록) — UserCredits +
// CreditTransaction 도입으로 대체. caller 0, row 0 으로 2026-06-06 삭제.

// 상담사 채팅 세션 - 프리미엄 대화 히스토리
model CounselorChatSession {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Service discriminator: "destiny" (single user) or "compat" (couple).
  // Existing rows default to "destiny" via the migration backfill.
  type String @default("destiny")

  // 세션 정보
  locale String  @default("ko")
  title  String? // user-editable chat title; sidebar falls back to summary/preview/id when null

  // 대화 메시지들 (JSON 배열)
  messages Json // [{role: "user"|"assistant", content: "...", timestamp: "..."}]

  // 세션 요약 (AI가 생성)
  summary   String? // 대화 요약 (다음 방문 시 참조용)
  keyTopics Json? // 주요 주제들 ["취업", "2025년 상반기"]

  // Type-specific persisted context. For compat: { persons, person1Saju,
  // person2Saju, person1Astro, person2Astro } so the past-chat link can
  // restore the full chart without re-fetching.
  meta Json?

  // 메타데이터
  messageCount  Int      @default(0)
  lastMessageAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([userId, type, updatedAt])
}

// 유저 크레딧 관리 - 플랜별 사용량 추적
model UserCredits {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 현재 플랜
  plan String @default("free") // free, starter, pro, premium

  // @deprecated 월간 충전 모델 폐지 — 제품은 "크레딧 구매 후 쓴 만큼 차감"
  // (bonusCredits 단일 풀). monthlyCredits/usedCredits 는 쓰기 로직이 모두
  // 제거되어 동결(frozen) 상태이며 잔액 계산 호환을 위해 컬럼만 남겨둠.
  // 물리 컬럼 드롭은 API/프론트 계약 변경을 동반하는 별도 마이그레이션으로.
  monthlyCredits     Int @default(1) // @deprecated (frozen) — 월간 충전 없음
  usedCredits        Int @default(0) // @deprecated (frozen) — 월간 소비량
  bonusCredits       Int @default(0) // 실제 잔액의 단일 진실원천 (구매/보너스)
  totalBonusReceived Int @default(0) // 총 받은 보너스 (total 계산용)

  // 기능별 사용량 (월간)
  compatibilityUsed Int @default(0) // 궁합 분석 사용 횟수
  followUpUsed      Int @default(0) // 후속질문 사용 횟수

  // 플랜별 한도
  compatibilityLimit Int @default(0) // 궁합 한도 (free:0, starter:2, pro:5, premium:10)
  followUpLimit      Int @default(0) // 후속질문 한도

  // 기간 추적
  periodStart DateTime  @default(now()) // 현재 월간 기간 시작
  periodEnd   DateTime? // 현재 월간 기간 종료

  // 히스토리 보관 기간 (일)
  historyRetention Int @default(7) // free:7, starter:30, pro:90, premium:365

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([periodEnd])
}

// 옛 SavedCalendarDate (날짜별 운세 score/grade 저장) — CalendarBuildCache /
// NatalContextCache 가 대체. 가짜 score/grade 정신과도 불일치. caller 0,
// row 0 으로 2026-06-06 삭제.

// 보너스 크레딧 구매/지급 기록 - 각 구매별 만료일 추적
model BonusCreditPurchase {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  // 크레딧 정보
  amount    Int // 구매한 크레딧 수
  remaining Int // 남은 크레딧 수

  // 만료 정보 (구매일로부터 3개월)
  expiresAt DateTime
  expired   Boolean  @default(false)

  // 구매 정보
  source          String  @default("purchase") // purchase, referral, promotion, gift
  // Stripe 결제 ID — 환불 매칭 + DB 레벨 webhook 멱등성용 unique.
  // nullable 이라 source != 'purchase' 행들은 NULL 로 여러 개 가능
  // (Postgres 의 nullable unique 동작).
  stripePaymentId String? @unique

  // 사용자에게 "+N 크레딧 받았어요" 모달을 보여주고 닫힌 시각.
  // null 이면 아직 모달 안 봤음 → 다음 페이지 진입/로그인 시 모달 노출.
  // source='purchase' (본인 결제) 는 Stripe success 페이지가 곧 acknowledgment
  // 이라 grant 시점에 createdAt 으로 채워 둠. source='referral' 같은 자동
  // 지급분만 null → 별도 모달.
  acknowledgedAt DateTime?

  @@index([userId])
  @@index([userId, expired])
  @@index([userId, acknowledgedAt])
  @@index([expiresAt])
}

// 새로고침/탭 복제 등 같은 API 호출이 재진입할 때 크레딧 중복 차감
// 방지용 멱등 키 저장소. 모듈 스코프 Map 만으로는 Vercel cold start 시
// 잊혀서 cold start 직후 새로고침이 더블 차지로 이어졌음. DB 저장으로
// instance 간 / 재시작 후에도 유지. 만료된 행은 cron 으로 정리.
model RequestIdempotencyLog {
  // (route|ownerKey|userIdempotencyKey) 형태의 단일 키.
  scopedKey String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// Stripe webhook 이 순서대로 안 도착하는 케이스 방어.
//
// 시나리오: 사용자가 결제 → 거의 동시에 dispute/refund → Stripe 가 두
// webhook(`checkout.session.completed`, `charge.refunded`) 을 동시에 보냄.
// 만약 `charge.refunded` 가 먼저 도착하면 `BonusCreditPurchase` 행이 아직
// 없어서 revokeBonusCreditPurchase() 가 no-op 으로 끝남. 그 후 `checkout
// .session.completed` 가 도착하면 크레딧이 정상 지급돼 사용자에게 환불 +
// 크레딧 둘 다 가는 leak.
//
// fix: refund webhook 이 매칭 purchase 못 찾으면 여기에 기록. purchase
// webhook 이 새 BonusCreditPurchase 만들고 즉시 이 테이블 조회 → 있으면
// 그 자리에서 회수 + 행 삭제. 어느 순서로 도착해도 결과 동일.
model PendingCreditRevocation {
  id                    String   @id @default(cuid())
  // checkout.session.completed 의 paymentIntentId 와 매칭하는 키.
  stripePaymentIntentId String   @unique
  // 운영 추적용 — refund 이벤트의 금액·시점.
  refundAmountCents     Int?
  currency              String?
  createdAt             DateTime @default(now())
  // 만료 — 보통 결제 webhook 은 수 초 안에 옴. 24h 안에 매칭 purchase 가
  // 안 생기면 stale (사용자 결제 자체가 실패한 경우). cron 으로 정리.
  expiresAt             DateTime

  @@index([expiresAt])
}

// 추천 보상 기록
model ReferralReward {
  id             String   @id @default(cuid())
  userId         String // 보상 받은 사람 (추천인)
  referredUserId String // 추천받아 가입한 사람
  createdAt      DateTime @default(now())

  // 보상 정보
  creditsAwarded Int    @default(3) // 지급된 크레딧
  rewardType     String @default("signup_complete") // signup_complete, first_analysis

  // 상태
  status      String    @default("pending") // pending, completed, expired
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, referredUserId, rewardType]) // 중복 보상 방지
  @@index([userId])
  @@index([referredUserId])
  @@index([status])
}

// 타로 리딩 결과 저장
model TarotReading {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  // 질문/관심사
  question String  @db.Text

  // 스프레드 정보
  spreadId    String // 스프레드 ID
  spreadTitle String // 스프레드 이름

  // 뽑은 카드들 (JSON)
  cards Json // [{cardId, name, image, isReversed, position}]

  // AI 해석 결과
  overallMessage String? @db.Text
  cardInsights   Json? // 카드별 해석
  guidance       String? @db.Text
  affirmation    String?

  // 출처 (counselor = 상담사 내 타로, standalone = 타로 페이지)
  source String @default("standalone")

  // 상담 세션 연결 (상담 중 타로인 경우)
  counselorSessionId String?

  // 커플 타로 (공유 리딩)
  isSharedReading  Boolean @default(false) // 커플 공유 리딩 여부
  sharedWithUserId String? // 공유 대상 파트너 ID
  paidByUserId     String? // 결제한 사용자 ID

  locale String @default("ko")

  // 보충 카드 (클래리파이어) — 사용자가 결과 화면에서 "한 장 더 뽑기"
  // 누르면 한 장 추가 추첨된 카드. 한 리딩당 한 장 한정. PATCH 로
  // 늦게 채워질 수 있음(저장 시점엔 null).
  clarifierCard Json? // { name, nameKo, isReversed, llmFollowupText? }

  // 결과 화면의 followup 채팅 ("이 리딩에 대해 더 묻기") 내역. 사용자가
  // 추가로 던진 질문 + LLM 답변 의 turn 배열. 저장 후에도 사용자가 더
  // 묻으면 PATCH 로 갱신.
  followupTurns Json? // [{ role: 'user' | 'assistant', content: string }]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sharedWithUserId, createdAt])
}

// 옛 PushSubscription (웹 푸시 알림 구독) — 등록 라우트 / 발송 코드 0.
// caller 0, row 0 으로 2026-06-06 삭제.

// 옛 EmailLog (이메일 발송 로그) — caller = me/account cascade delete 한
// 줄, create 0. 발송 코드 자체가 dead. 2026-06-06 제거.

// PersonalityResult (Nova Persona) / ICPResult (대인관계 스타일) — 페이지
// 제거 후 schema 만 orphan. 2026-06-06 통째 정리 (row 0).
// PastLifeResult 도 2026-05-27 migration 으로 drop.

// 옛 CompatibilityResult (ICP / Persona 궁합 점수 결과) — ICPResult /
// PersonalityResult 모델이 이미 삭제됐고 이 모델도 caller 0, row 0.
// 궁합 새 시스템은 compatSajuFacts/compatAstroFacts + LLM. 2026-06-06 삭제.

// 🔒 Admin Audit Log - 관리자 작업 감사 로그
model AdminAuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // 관리자 정보
  adminEmail  String
  adminUserId String?

  // 작업 정보
  action     String // refund_subscription, update_credits, ban_user, etc.
  targetType String? // user, subscription, credit, etc.
  targetId   String? // 대상의 ID

  // 작업 세부사항 (JSON)
  metadata Json? // { amount, reason, before, after, etc. }

  // 결과
  success      Boolean @default(true)
  errorMessage String?

  // IP 및 User Agent
  ipAddress String?
  userAgent String?

  @@index([adminEmail, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// 옛 CreditRefundLog — CreditTransaction 의 type='REFUND' row 가 SSOT 라
// 별도 로그 중복. 외부 caller (getCreditRefundHistory /
// getRefundStatsByRoute) 0. 2026-06-06 제거.

// 🔗 Shared Result - 공유된 결과 저장
model SharedResult {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime? // 만료 시간 (null = 영구)

  // 공유자 정보
  userId String? // 비로그인 공유도 허용

  // 결과 타입
  resultType String // saju, tarot, astrology, dream, compatibility, personality, icp

  // 결과 내용
  title       String
  description String? @db.Text
  resultData  Json? // 추가 데이터 (선택)

  // 조회 통계
  viewCount Int @default(0)

  @@index([userId, createdAt])
  @@index([resultType, createdAt])
}

// 💳 Stripe Event Log - 웹훅 이벤트 중복 처리 방지 (멱등성)
model StripeEventLog {
  id          String   @id @default(cuid())
  eventId     String   @unique // Stripe event.id
  type        String // event.type (checkout.session.completed, etc.)
  processedAt DateTime @default(now())
  success     Boolean  @default(true)
  errorMsg    String?
  metadata    Json? // 디버깅용 메타데이터

  @@index([type, processedAt])
  @@index([processedAt])
}

// 옛 UserBlock / UserReport (destiny-match 차단 & 신고) — destiny-match
// 본체 제거 (PR #1218) 후 잔재. caller 0, row 0 으로 2026-06-06 삭제.

// 🔒 Security Audit Log - 보안 이벤트 로그
model SecurityAuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // 이벤트 분류
  category String // auth, admin, token, data, security, api
  action   String // login, logout, rate_limit_exceeded, suspicious_injection_attempt, etc.
  severity String // info, warn, error, critical

  // 결과
  success Boolean @default(true)

  // 사용자/세션 정보
  userId    String?
  userEmail String?

  // 요청 정보
  ipAddress String?
  userAgent String? @db.Text
  path      String?
  method    String?

  // 추가 정보 (JSON)
  details Json?

  // 에러 메시지
  errorMessage String? @db.Text

  @@index([category, createdAt])
  @@index([severity, createdAt])
  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([action, createdAt])
}

// 📊 익명 방문 로그 — 비로그인 방문자까지 포함한 트래픽 집계용.
// visitorId 는 "일별 회전 해시" (sha256(날짜+ip+ua+salt))라 원본 IP/UA 를
// 저장하지 않고 같은 날 같은 방문자를 묶을 수만 있다(다음날이면 다른 해시).
// 따라서 개인 식별 불가 + 쿠키 불필요 → 동의 배너와 무관한 1st-party 익명
// 분석. 어드민 '방문자' 탭에서 일별 순방문자/페이지뷰/로그인 전환을 본다.
model PageView {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  visitorId    String // 일별 회전 익명 해시 (원본 PII 아님)
  path         String // pathname only (쿼리스트링 제거)
  referrerHost String? // referrer hostname only (외부 유입 출처)
  isLoggedIn   Boolean  @default(false)
  userId       String? // 로그인 상태일 때만 기록 (FK 없음 — 경량 로그)
  country      String? // x-vercel-ip-country 헤더 (있으면)
  device       String? // 거친 분류: mobile/tablet/desktop/bot

  @@index([createdAt])
  @@index([visitorId, createdAt])
  @@index([isLoggedIn, createdAt])
  @@index([path, createdAt])
}

/// calendar-engine v2 — 1 사용자 1 월치 빌드 결과 캐시.
/// 본명 입력 + 월 키로 unique. 같은 입력이면 cell 데이터 재계산 없이 반환.
/// 영구 캐시 (본명 변동 없으면 결과도 결정적).
model CalendarBuildCache {
  id        String   @id @default(cuid())
  /// hash(birthDate + birthTime + birthPlace + gender + 'v2')
  birthKey  String
  /// 'YYYY-MM' (예: '2026-05')
  monthKey  String
  /// CalendarCell[] JSON (engineSignals · matchedPatterns · derivedScore · themeScores 등)
  data      Json
  builtAt   DateTime @default(now())

  @@unique([birthKey, monthKey])
  @@index([builtAt])
}

/// 본명 차트 영구 캐시.
/// CalendarBuildCache (월별 derived cells) 와 별개 — 이건 사용자별 한 번 계산 후
/// 영구. 사주 8글자 / 격국·용신 / 신살 / 합/충 / 대운 + 점성 차트 모두 포함된
/// NatalContext 통째로 JSON 저장. 차트 모달 / 캘린더 빌드 / 운명상담사 prompt
/// 빌드 등 본명 데이터 필요한 모든 경로가 이 캐시 우선 조회.
///
/// engineSignature 가 바뀐 row 는 stale 처리 — 다음 요청에 재계산해서 덮어씀.
/// Redis 캐시 (TTL 30일) 가 앞단에 있고 이건 cold fallback / 영구 보존용.
model NatalContextCache {
  id               String   @id @default(cuid())
  /// hash(birthDate + birthTime + latitude + longitude + gender + engineSignature)
  birthKey         String   @unique
  /// 엔진 버전 시그니처. 사주/점성 엔진 변경 시 bump.
  engineSignature  String
  /// NatalContext 전체 JSON — saju.pillars/dayMaster/yongsin/geokguk/strength/
  /// natalShinsal/natalRelations/daeun + astro.chart/extraPoints/sect/location.
  data             Json
  builtAt          DateTime @default(now())

  @@index([builtAt])
  @@index([engineSignature])
}

// 크레딧 변동 감사 테이블 — 모든 mutation 경로 (grant / consume / refund /
// expire / revoke / signup_bonus) 가 자기 행을 1 개씩 남긴다. 기존 분산
// 로그(CreditRefundLog / AdminAuditLog / BonusCreditPurchase) 와 중복이지만
// 단일 시계열 (userId + createdAt DESC) 로 잔액 변동을 재현할 수 있어야
// 정합성 감사·환불 분쟁 추적·내부 BI 가 가능.
//
// 핵심 invariant:
//   sum(amount where userId=X) ==
//     UserCredits.bonusCredits + (UserCredits.monthlyCredits - UserCredits.usedCredits)
//     - 0  (CreditTransaction 가 도입된 시점부터의 변화량만 추적)
// 백필 스크립트가 deploy 시점까지의 historical GRANT/REFUND 를 채워 넣고,
// CONSUME 은 deploy 이후만 정확. 자세한 사항은
// scripts/backfill-credit-transactions.ts 헤더 참조.
enum CreditTxnType {
  GRANT
  CONSUME
  REFUND
  EXPIRE
  REVOKE
  SIGNUP_BONUS
}

enum CreditPool {
  BONUS
  MONTHLY
  COMPATIBILITY
  FOLLOWUP
}

model CreditTransaction {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      CreditTxnType
  pool      CreditPool
  // 부호 있는 값 — GRANT/REFUND/SIGNUP_BONUS 는 양수, CONSUME/EXPIRE/REVOKE
  // 는 음수. sum 으로 잔액 변화를 바로 계산할 수 있다.
  amount    Int
  reason    String
  // 외부 키 (stripePaymentId / bonusCreditPurchaseId / referralRewardId /
  // adminAuditLogId 등). 분쟁/감사 추적용. 가능하면 채워 둘 것.
  sourceRef String?
  // 보조 컨텍스트 (예: { fromBonus: n, fromMonthly: m, apiRoute, errorMessage }).
  // PII 가 들어갈 수 있으므로 외부 노출 금지 (history API 응답 제외).
  metadata  Json?
  createdAt DateTime      @default(now())

  // ── Ledger SSOT 확장 (Phase 0 — additive only, 현재 코드 미사용) ──
  // 잔액 = 거래합(ledger) 전환을 위한 컬럼들. 전부 nullable 이라 기존 동작 무영향.
  // 설계: docs/architecture/credit-ledger-redesign.md
  // 이 row 가 속한 보너스 lot(구매 단위). FIFO·만료를 ledger 안에서 표현하는 키.
  lotId          String?
  // GRANT(BONUS) row 의 lot 만료 시각 (만료 스윕용).
  expiresAt      DateTime?
  // MONTHLY 풀 기간 키 (예: '2026-06'). 현재 월간 충전 없음 → 당장은 nullable.
  period         String?
  // charge/grant 멱등 키 — "한 번만 기록" 을 DB unique 로 강제 (현재는 흩어진
  // RequestIdempotencyLog / stripePaymentId / refundOnce 를 장기적으로 흡수).
  idempotencyKey String?       @unique

  @@index([userId, createdAt(sort: Desc)])
  @@index([sourceRef])
  @@index([type, createdAt])
  @@index([userId, pool, createdAt])
  @@index([lotId])
  @@index([expiresAt])
}
