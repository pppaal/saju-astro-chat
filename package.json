{
  "name": "saju-astro-chatbot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "postinstall": "prisma generate --config prisma.config.ts",
    "cities:translate-kr": "python3 scripts/translate-cities-kr.py",
    "cities:build-kr-geonames": "python3 scripts/build-city-names-kr-geonames.py",
    "cities:filter-translated": "python3 scripts/filter-cities-to-translated.py",
    "vercel-build": "prisma generate --config prisma.config.ts && node scripts/prisma-migrate-recovery.js && prisma migrate deploy && node scripts/prisma-schema-verify.js && node scripts/copy-pdf-worker.mjs && next build",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "node scripts/copy-pdf-worker.mjs && next build",
    "build:webpack": "cross-env NEXT_PRIVATE_DISABLE_TURBOPACK=1 node scripts/copy-pdf-worker.mjs && next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "audit:unused": "cross-env DATABASE_URL=postgresql://placeholder:placeholder@localhost:5432/placeholder knip --include files,exports,dependencies",
    "audit:personality-questions": "tsx scripts/audit-personality-questions.ts",
    "audit:assessment": "tsx scripts/audit-assessment-content.ts",
    "reconcile:stripe": "tsx scripts/reconcile-stripe-purchases.ts",
    "review:assessment": "node scripts/review-assessment-examples.mjs",
    "eval:strategy:batch": "tsx scripts/evaluate-strategy-batch.ts --samples 100 --out reports/strategy_batch_eval_latest.json",
    "eval:deterministic:batch": "tsx scripts/evaluate-deterministic-report-batch.ts --samples 240 --out reports/quality/deterministic_batch_eval_latest.json",
    "lint:mojibake": "node scripts/check-mojibake-lint.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:watch": "tsc -p tsconfig.json --watch --noEmit",
    "ops:typecheck:gate": "node scripts/typecheck-gate.mjs",
    "ops:typecheck:update-baseline": "node scripts/typecheck-metrics.mjs --out reports/typecheck/baseline.json",
    "test": "vitest run",
    "test:fast": "vitest run --exclude tests/components/ui-components.test.tsx --exclude tests/lib/modules-smoke.test.ts --exclude tests/app/api/astrology/advanced/routes.integration.test.ts --exclude tests/app/api/destiny-matrix/report/route.test.ts --exclude tests/app/api/auth/register/route.comprehensive.test.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run tests/a11y",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:wait": "node scripts/wait-for-server.mjs",
    "test:integration": "vitest run tests/integration",
    "test:integration:setup": "node -e \"console.log('Run: .\\\\scripts\\\\setup-test-db.ps1 (Windows) or bash scripts/setup-test-db.sh (Linux/Mac)')\"",
    "test:tarot": "vitest run tests/lib/Tarot",
    "test:tarot:question-golden": "vitest run tests/lib/Tarot/questionEngineGoldenSet.test.ts",
    "test:tarot:fallback-quality": "vitest run tests/lib/Tarot/fallbackQualityGoldenSet.test.ts",
    "test:tarot:interpret-quality": "vitest run tests/lib/Tarot/interpretationQualityBenchmark.test.ts",
    "test:ephemeris-golden": "tsx scripts/ephemeris-golden.mts",
    "test:destiny:release": "vitest run tests/lib/report/integratedReport.real.test.ts tests/lib/report/integratedReport.render.test.ts",
    "test:nightly:shard": "node scripts/ops/run-vitest-shard.mjs",
    "qa:tarot:engine": "tsx scripts/tarot-question-engine-report.ts --out reports/quality/tarot_question_engine_latest.json",
    "qa:tarot:full": "npm run qa:tarot:engine && npx tsx scripts/eval-tarot-question-sample.ts --count 80 --seed 20260324 --concurrency 12",
    "eval:tarot:export": "tsx scripts/export-tarot-user-eval.ts --limit 500 --days 120 --out reports/quality/tarot_user_eval_seed.jsonl",
    "test:destiny-map": "vitest run tests/destiny-map-api-smoke.test.ts tests/destiny-map-sanitize.test.ts tests/destinyCalendar.test.ts tests/lib/destiny-map/destinyCalendar.test.ts",
    "test:performance": "vitest run tests/performance/web-vitals.test.ts --reporter=verbose",
    "test:performance:check": "node tests/performance/check-server.js",
    "test:load:basic": "k6 run tests/performance/k6/basic-load.js",
    "test:load:stress": "k6 run tests/performance/k6/stress-test.js",
    "test:load:spike": "k6 run tests/performance/k6/spike-test.js",
    "db:migrate": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "tarot:eval": "tsx scripts/tarot/eval.ts",
    "db:studio": "prisma studio",
    "test:load:endurance": "k6 run tests/performance/k6/endurance-test.js",
    "test:load:realistic": "k6 run tests/performance/k6/realistic-scenario.js",
    "test:load:event": "k6 run tests/performance/k6/event-launch.js",
    "security:owasp": "node scripts/owasp-zap-baseline.mjs",
    "test:e2e:browser": "playwright test",
    "test:e2e:smoke:public": "playwright test e2e/public-pages-smoke.spec.ts",
    "test:e2e:calendar": "playwright test --config=playwright.calendar.config.ts",
    "test:e2e:critical": "playwright test --config=playwright.ci.config.ts e2e/critical-flows e2e/myjourney-core-services-persistence.spec.ts",
    "test:ssr-placeholders": "node scripts/check-ssr-placeholders.mjs",
    "test:mojibake:smoke": "node scripts/smoke-mojibake-html.mjs",
    "test:e2e:api": "cross-env VITEST_INCLUDE_E2E=1 vitest run tests/e2e",
    "test:e2e:auth": "playwright test e2e/critical-flows/01-registration-auth.spec.ts",
    "test:e2e:tarot": "playwright test e2e/critical-flows/02-tarot-reading.spec.ts",
    "test:e2e:saju": "playwright test e2e/critical-flows/03-saju-analysis.spec.ts",
    "test:e2e:compatibility": "playwright test e2e/critical-flows/04-compatibility-flow.spec.ts",
    "test:e2e:credits": "playwright test e2e/critical-flows/05-credit-management.spec.ts",
    "test:e2e:profile": "playwright test e2e/critical-flows/06-profile-management.spec.ts",
    "test:e2e:premium": "playwright test e2e/critical-flows/07-premium-subscription.spec.ts",
    "test:e2e:destiny": "playwright test e2e/critical-flows/08-destiny-features.spec.ts",
    "qa:counselor-calendar:report": "tsx scripts/qa-counselor-calendar-report.ts",
    "test:unit": "cross-env TS_NODE_COMPILER_OPTIONS={\"module\":\"commonjs\",\"jsx\":\"react-jsx\"} node -r ts-node/register --test tests/*.test.ts",
    "test:lang-purity": "node scripts/check-language-purity.mjs",
    "regen:themed": "node scripts/regenerate-themed-report.mjs",
    "dev:astro": "ts-node -P tsconfig.scripts.json -r tsconfig-paths/register scripts/dev-astro.ts",
    "check:env": "node scripts/validate-env.js",
    "check:all": "npm run lint && npm run lint:mojibake && npm run typecheck && npm test",
    "quality:check": "npm run lint && npm run typecheck && npm run test:coverage",
    "migrate:logger": "node scripts/migrate-console-to-logger.js",
    "marketing:auto-post": "node scripts/auto-post-daily-fortune.mjs",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:sync:android": "npm run build && npx cap sync android",
    "mobile:sync:ios": "npm run build && npx cap sync ios",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "security:audit": "npm audit --audit-level=high",
    "audit:api": "node scripts/audit-api-routes.mjs",
    "docs:stats": "node scripts/repo-stats.mjs",
    "docs:generate": "npx tsx scripts/generate-openapi.ts",
    "docs:check-links": "node scripts/check_docs_links.js",
    "docs:sync": "tsx scripts/docs/generate.ts",
    "docs:sync:check": "tsx scripts/docs/generate.ts --check",
    "blog:index": "tsx scripts/blog/generate-index.ts",
    "prepare": "husky",
    "ops:slo:report": "node scripts/ops/slo-report.mjs",
    "ops:typecheck:metrics": "node scripts/ops/typecheck-metrics.mjs",
    "ops:typecheck:hotspots": "node scripts/ops/typecheck-hotspots.mjs",
    "ops:destiny:gate:quick": "node scripts/ops/destiny-quality-gate.mjs --quick",
    "ops:destiny:gate": "node scripts/ops/destiny-quality-gate.mjs --full",
    "ops:destiny:nightly": "npm run test:nightly:shard -- --index=0 --total=1 && npm run ops:destiny:gate",
    "ops:destiny:release": "npm run typecheck && npm run test:destiny:release"
  },
  "overrides": {
    "node-gyp": "^10.0.1",
    "glob": "^10.4.7",
    "lodash": "^4.17.23",
    "hono": "^4.12.25",
    "diff": "^4.0.4",
    "tar": "^7.5.20",
    "protobufjs": "^7.5.6",
    "serialize-javascript": "^7.0.5",
    "form-data": "^4.0.6",
    "ws": "^8.18.3",
    "undici": "^6.27.0",
    "nodemailer": "^9.0.3",
    "swisseph": {
      "node-gyp": "^10.0.1"
    },
    "axios": "^1.18.1",
    "js-yaml": "^4.3.0",
    "brace-expansion": "^2.1.2",
    "fast-uri": "^3.1.4",
    "sharp": "^0.35.3"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/nextjs": "^10.38.0",
    "@upstash/redis": "^1.36.2",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.4",
    "framer-motion": "^12.33.0",
    "html-to-image": "^1.11.13",
    "korean-lunar-calendar": "^0.3.6",
    "lru-cache": "^11.2.5",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.31",
    "pdfjs-dist": "^5.4.624",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "stripe": "^19.3.1",
    "swagger-ui-react": "^5.31.0",
    "swisseph": "^0.5.17",
    "tailwind-merge": "^3.4.0",
    "tz-lookup": "^6.1.25",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "src/config/enabledServices.ts": [
      "npm run docs:sync",
      "git add docs"
    ],
    "src/lib/config/calculationStandards.ts": [
      "npm run docs:sync",
      "git add docs"
    ],
    "src/lib/tarot/tarot-spreads-data.ts": [
      "npm run docs:sync",
      "git add docs"
    ]
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.2",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/tz-lookup": "^6.1.2",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.24",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "lint-staged": "^16.2.7",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prisma": "^7.3.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "web-vitals": "^5.1.0",
    "webpack": "^5.105.0"
  }
}
