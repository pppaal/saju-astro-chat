{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "tsBuildInfoFile": "./tmp/tsconfig.tsbuildinfo",
    "allowImportingTsExtensions": false,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "**/*.d.ts",
    "next-env.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/lib/api/openapi/**/*",
    "tmp/**/*",
    "tmp/.next-playwright-calendar/**/*",
    "tmp/.next-playwright-tarot/**/*"
  ]
}
