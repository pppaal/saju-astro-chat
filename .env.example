# ============================================================
# Application
# ============================================================
# Base URL of the deployed site (used for metadata, OG images, sitemap)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NextAuth callback URL - must match NEXT_PUBLIC_BASE_URL in production
NEXTAUTH_URL=http://localhost:3000
# Cookie domain for cross-subdomain auth (e.g. ".destinypal.com")
NEXTAUTH_COOKIE_DOMAIN=.example.com
# Random string, 32+ characters. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me
# Encryption key for OAuth tokens. Must be 32 bytes (ASCII or base64)
TOKEN_ENCRYPTION_KEY=32_byte_base64_or_ascii_key

# ============================================================
# Database — Supabase Postgres
# ============================================================
# IMPORTANT (serverless): use the Supabase *transaction pooler* (port 6543) with
# `pgbouncer=true`, NOT the direct connection (port 5432, db.<ref>.supabase.co).
# The direct connection has a small fixed connection cap and exhausts fast under
# Vercel serverless concurrency, which surfaces as intermittent sign-in
# "Server error / Configuration" pages. Get the URL from:
#   Supabase Dashboard > Project Settings > Database > Connection string > "Transaction pooler"
# Example format:
#   postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# Migrations automatically switch this to the session pooler (5432) — see prisma.config.ts.
DATABASE_URL=postgresql://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Connection pool tuning (optional — sensible serverless defaults applied if unset).
# 인스턴스당 풀 max 기본값 = 5. Supabase 풀러 + Vercel 서버리스에서 총 커넥션은
# max × 인스턴스 수라, 옛 기본 15는 배포 컷오버/스파이크에 ECHECKOUTTIMEOUT
# (커넥션 풀 고갈)을 유발했다. 일반적으로 올릴 필요 없음 — 풀러가 멀티플렉싱한다.
# DATABASE_POOL_MAX=5
# DATABASE_POOL_IDLE_TIMEOUT_MS=10000
# DATABASE_CONNECTION_TIMEOUT_MS=10000
# DATABASE_POOL_MAX_USES=7500

# ============================================================
# AI Provider — Anthropic Claude
# ============================================================
# Anthropic Claude — primary (and only) LLM provider.
# Used by counselor chat, tarot interpretation, calendar polish, etc.
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=replace_me

# ============================================================
# Payments (Stripe)
# ============================================================
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=replace_me
# Webhook signing secret from Stripe endpoint settings
STRIPE_WEBHOOK_SECRET=replace_me
# One-time credit pack price IDs (Stripe Products → Prices → price_xxx)
STRIPE_PRICE_CREDIT_MINI=price_credit_mini
STRIPE_PRICE_CREDIT_STANDARD=price_credit_standard
STRIPE_PRICE_CREDIT_PLUS=price_credit_plus
STRIPE_PRICE_CREDIT_MEGA=price_credit_mega
STRIPE_PRICE_CREDIT_ULTIMATE=price_credit_ultimate

# ============================================================
# OAuth Providers
# ============================================================
# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me

# ============================================================
# Firebase Storage (image uploads)
# ============================================================
# JSON string of Firebase config object from Firebase Console > Project Settings.
# Used for profile and matching photo uploads. If empty, upload UI shows a
# "service not configured" message and the rest of the app works fine.
NEXT_PUBLIC_FIREBASE_CONFIG=replace_me

# ============================================================
# Redis / Upstash (optional — enables caching and rate limiting)
# ============================================================
# Upstash REST API - https://console.upstash.com/ (recommended for serverless)
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=replace_me
# Standard Redis connection (alternative to Upstash)
REDIS_URL=redis://default:password@host:6379/0

# ============================================================
# Admin & API Tokens
# ============================================================
# Admin API access token. Generate: openssl rand -hex 32
ADMIN_API_TOKEN=replace_me
# Comma-separated admin email addresses (env-based fallback;
# DB role check takes precedence — see src/lib/auth/admin.ts)
ADMIN_EMAILS=admin@example.com
# Public API token for unauthenticated endpoints
PUBLIC_API_TOKEN=replace_me
NEXT_PUBLIC_API_TOKEN=replace_me
# Token for public metrics endpoint access
PUBLIC_METRICS_TOKEN=replace_me
NEXT_PUBLIC_PUBLIC_METRICS_TOKEN=replace_me
# CORS allowed origins (comma-separated). Example: https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# Monitoring & Analytics
# ============================================================
# Sentry DSN - https://sentry.io/ > Project Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=replace_me

# Google Analytics Measurement ID - https://analytics.google.com/
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Microsoft Clarity Project ID - https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ============================================================
# SEO Verification
# ============================================================
# Google Search Console - https://search.google.com/search-console/
NEXT_PUBLIC_GOOGLE_VERIFICATION=replace_me
# Yandex Webmaster - https://webmaster.yandex.com/
NEXT_PUBLIC_YANDEX_VERIFICATION=replace_me

# ============================================================
# Push Notifications (Web Push VAPID)
# ============================================================
# Generate key pair: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace_me
# Server-side public key (optional — falls back to NEXT_PUBLIC_VAPID_PUBLIC_KEY)
VAPID_PUBLIC_KEY=replace_me
VAPID_PRIVATE_KEY=replace_me
# Contact email for push service. Format: mailto:you@domain.com
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ============================================================
# Email Notifications — Resend
# ============================================================
# Provider id (only "resend" is wired; SendGrid/Nodemailer stubs are
# commented out in src/lib/email/providers/index.ts for future expansion).
EMAIL_PROVIDER=resend
# Sender name and address — must be a verified Resend sender domain
EMAIL_FROM=DestinyPal <noreply@destinypal.com>
# Resend API key - https://resend.com/api-keys
RESEND_API_KEY=replace_me

# ============================================================
# Cron Jobs
# ============================================================
# Secret for authenticating cron job requests. Generate: openssl rand -hex 32
CRON_SECRET=replace_me_with_random_string
# Public support contact email for Contact/Policy pages
NEXT_PUBLIC_SUPPORT_EMAIL=rheeco88@gmail.com
# Server-side support contact email (optional; falls back to NEXT_PUBLIC_SUPPORT_EMAIL)
SUPPORT_EMAIL=rheeco88@gmail.com

# ============================================================
# Optional — daily fortune image generation cron
# ============================================================
# Replicate token for the daily-fortune image cron (scripts/auto-post-daily-fortune.mjs).
# Leave empty if you do not run that script.
REPLICATE_API_TOKEN=

# ============================================================
# Testing / Dev
# ============================================================
# 크레딧 검사·차감 우회. true 로 켜면 타로/궁합/운명 등 모든 크레딧 게이트가
# 통과된다. 운영 빌드에서도 동작하므로(배포 환경 테스트용) 실제 과금에 직접
# 영향을 준다. 켜지면 서버 로그에 경고가 남는다. 테스트가 끝나면 반드시 끌 것.
CREDITS_BYPASS=false
